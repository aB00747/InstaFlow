{
  "instagram": {
    "user_id": "YOUR_INSTAGRAM_USER_ID",
    "access_token": "YOUR_LONG_LIVED_ACCESS_TOKEN"
  },
  "imgbb": {
    "api_key": "YOUR_IMGBB_API_KEY"
  },
  "email": {
    "smtp_host": "smtp.gmail.com",
    "smtp_port": 587,
    "sender": "your.gmail@gmail.com",
    "app_password": "YOUR_APP_PASSWORD",
    "recipient": "notify@youremail.com"
  },
  "telegram": {
    "bot_token": "YOUR_BOT_TOKEN",
    "chat_id": "YOUR_CHAT_ID"
  },
  "_note": "smtp_host/smtp_port are used by setup_test.py only. poster.py always uses Gmail (smtp.gmail.com:587). Post schedule is set by GitHub Actions cron in .github/workflows/daily_post.yml.",
  "settings": {
    "images_folder": "./images",
    "captions_file": "./captions.txt",
    "posted_file": "./posted.json"
  }
}
